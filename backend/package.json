{
  "name": "cco-kidscam-api",
  "version": "1.0.0",
  "description": "API REST para el sistema KidScam — Centro Cristiano de Obrapía / Ministerio Vías en Acción",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.js",
    "start": "node src/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify": "^5.3.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/autoload": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "zod": "^3.24.0",
    "xlsx": "^0.18.5",
    "csv-parse": "^5.6.0",
    "nodemailer": "^6.10.0",
    "dotenv": "^16.4.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "supertest": "^7.0.0"
  }
}
