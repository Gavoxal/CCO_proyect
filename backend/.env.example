# ==========================
# BASE DE DATOS
# ==========================
DATABASE_URL="mysql://usuario:password@localhost:3306/cco_kidscam"

# ==========================
# JWT
# ==========================
JWT_SECRET="cambiar-por-secreto-seguro-de-al-menos-32-caracteres"
JWT_EXPIRES_IN="8h"

# ==========================
# SERVIDOR
# ==========================
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ==========================
# EMAIL (Nodemailer)
# ==========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=correo@gmail.com
